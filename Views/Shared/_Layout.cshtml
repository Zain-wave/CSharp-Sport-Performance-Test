<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Athletic Management Hub</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@400;500;600;700;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "brand-green-mid": "#2E7D32",
                        "brand-green-dark": "#1B5E20",
                        "brand-green-light": "#A5D6A7",
                        "outline": "#717a6d",
                        "outline-variant": "#c0c9bb",
                        "surface": "#f7fbf1",
                        "surface-primary": "#FFFFFF",
                        "surface-secondary": "#F5F5F5",
                        "surface-dim": "#d8dbd2",
                        "surface-variant": "#e0e4db",
                        "surface-container": "#ecefe6",
                        "surface-container-low": "#f2f5ec",
                        "surface-container-high": "#e6e9e0",
                        "surface-container-highest": "#e0e4db",
                        "surface-bright": "#f7fbf1",
                        "on-surface": "#191d17",
                        "on-surface-variant": "#41493e",
                        "on-background": "#191d17",
                        "on-primary": "#ffffff",
                        "on-secondary": "#ffffff",
                        "on-tertiary": "#ffffff",
                        "background": "#f7fbf1",
                        "text-main": "#424242",
                        "primary": "#00450d",
                        "primary-fixed": "#acf4a4",
                        "primary-fixed-dim": "#91d78a",
                        "primary-container": "#1b5e20",
                        "on-primary-fixed": "#002203",
                        "on-primary-fixed-variant": "#0c5216",
                        "on-primary-container": "#90d689",
                        "inverse-primary": "#91d78a",
                        "secondary": "#1b6d24",
                        "secondary-fixed": "#a3f69c",
                        "secondary-fixed-dim": "#88d982",
                        "secondary-container": "#a0f399",
                        "on-secondary-fixed": "#002204",
                        "on-secondary-fixed-variant": "#005312",
                        "on-secondary-container": "#217128",
                        "tertiary": "#6b1d3d",
                        "tertiary-fixed": "#ffd9e2",
                        "tertiary-fixed-dim": "#ffb1c8",
                        "tertiary-container": "#883454",
                        "on-tertiary-fixed": "#3e001d",
                        "on-tertiary-fixed-variant": "#7a2949",
                        "on-tertiary-container": "#ffaec6",
                        "surface-tint": "#2a6b2c",
                        "inverse-surface": "#2d322c",
                        "inverse-on-surface": "#eff2e9",
                        "error": "#ba1a1a",
                        "error-container": "#ffdad6",
                        "on-error": "#ffffff",
                        "on-error-container": "#93000a",
                        "status-error": "#D32F2F",
                        "status-warning": "#FFB300",
                        "status-success": "#1B5E20"
                    },
                    borderRadius: {
                        "DEFAULT": "0.125rem",
                        "lg": "0.25rem",
                        "xl": "0.5rem",
                        "full": "0.75rem"
                    },
                    spacing: {
                        "container-padding": "24px",
                        "sidebar-width": "280px",
                        "base": "8px",
                        "gutter": "16px",
                        "navbar-height": "64px"
                    },
                    fontFamily: {
                        "h1": ["Lexend"], "h2": ["Lexend"], "h3": ["Lexend"],
                        "body-base": ["Lexend"], "body-sm": ["Lexend"],
                        "label-caps": ["Lexend"], "button": ["Lexend"]
                    },
                    fontSize: {
                        "h1": ["2.25rem", { lineHeight: "1.2", letterSpacing: "-0.02em", fontWeight: "700" }],
                        "h2": ["1.5rem",   { lineHeight: "1.3", letterSpacing: "-0.01em", fontWeight: "600" }],
                        "h3": ["1.25rem",  { lineHeight: "1.4", letterSpacing: "0",       fontWeight: "600" }],
                        "body-base": ["1rem",     { lineHeight: "1.5", letterSpacing: "0", fontWeight: "400" }],
                        "body-sm":   ["0.875rem", { lineHeight: "1.5", letterSpacing: "0", fontWeight: "400" }],
                        "label-caps":["0.75rem",  { lineHeight: "1rem", letterSpacing: "0.05em", fontWeight: "600" }],
                        "button":    ["0.9375rem",{ lineHeight: "1",   letterSpacing: "0.01em", fontWeight: "500" }]
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Lexend', sans-serif; }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="bg-background text-on-background min-h-screen flex font-body-base">

    <!-- Sidebar -->
    <nav class="hidden md:flex flex-col fixed left-0 top-0 z-40 h-full w-[280px] py-6 bg-green-900 border-r border-green-800 shadow-lg text-sm font-medium">
        <div class="px-6 mb-8">
            <h1 class="text-white font-black text-xl">Gestión Deportiva</h1>
            <p class="text-green-100/70 text-xs mt-1">Panel Institucional</p>
        </div>
        <div class="flex-1 overflow-y-auto space-y-1">
            @{
                var ctrl = ViewContext.RouteData.Values["controller"]?.ToString();
            }
            <a href="/Usuario"
               class="mx-2 px-4 py-3 flex items-center gap-3 rounded-md transition-all
                      @(ctrl == "Usuario" ? "bg-green-800 text-white" : "text-green-100/70 hover:text-white hover:bg-green-800/50")">
                <span class="material-symbols-outlined">group</span>
                Usuarios
            </a>
            <a href="/EspacioDeportivo"
               class="mx-2 px-4 py-3 flex items-center gap-3 rounded-md transition-all
                      @(ctrl == "EspacioDeportivo" ? "bg-green-800 text-white" : "text-green-100/70 hover:text-white hover:bg-green-800/50")">
                <span class="material-symbols-outlined">stadium</span>
                Espacios Deportivos
            </a>
            <a href="/Reserva" 
               class="mx-2 px-4 py-3 flex items-center gap-3 rounded-md transition-all
                      @(ctrl == "Reserva" ? "bg-green-800 text-white" : "text-green-100/70 hover:text-white hover:bg-green-800/50")">
                <span class="material-symbols-outlined">event_available</span>
                Reservas
            </a>
        </div>
        <div class="mt-auto pt-4 border-t border-green-800 mx-4 space-y-1">
            <a href="#" class="px-2 py-3 flex items-center gap-3 rounded-md text-green-100/70 hover:text-white hover:bg-green-800/50 transition-all">
                <span class="material-symbols-outlined">settings</span>
                Configuración
            </a>
            <a href="#" class="px-2 py-3 flex items-center gap-3 rounded-md text-green-100/70 hover:text-white hover:bg-green-800/50 transition-all">
                <span class="material-symbols-outlined">logout</span>
                Cerrar Sesión
            </a>
        </div>
    </nav>

    <!-- Main wrapper -->
    <div class="flex-1 md:ml-[280px] flex flex-col min-h-screen">

        <!-- Top bar -->
        <header class="sticky top-0 z-30 flex justify-between items-center w-full px-6 py-2 h-16
                       bg-white border-b border-slate-200 shadow-sm">
            <span class="text-lg font-bold text-green-900 uppercase tracking-wider">
                Athletic Management Hub
            </span>
            <div class="flex items-center gap-4">
                <div class="relative hidden sm:block">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm">search</span>
                    <input type="text" placeholder="Buscar..."
                           class="pl-10 pr-4 py-1.5 border border-slate-200 rounded text-sm bg-surface-secondary text-text-main
                                  focus:border-brand-green-mid focus:ring-1 focus:ring-brand-green-mid outline-none" />
                </div>
                <button class="relative p-2 text-slate-500 hover:bg-slate-50 rounded-full transition-colors">
                    <span class="material-symbols-outlined">notifications</span>
                    <span class="absolute top-1 right-1 w-2 h-2 bg-status-error rounded-full"></span>
                </button>
                <button class="p-2 text-slate-500 hover:bg-slate-50 rounded-full transition-colors">
                    <span class="material-symbols-outlined">help</span>
                </button>
                <div class="w-8 h-8 rounded-full bg-green-800 flex items-center justify-center text-white text-xs font-bold">
                    AD
                </div>
            </div>
        </header>

        <!-- Page content -->
        <main class="flex-1 p-[24px] bg-surface-secondary overflow-y-auto">
            @if (TempData["Mensaje"] != null)
            {
                <div class="mb-4 px-4 py-3 rounded border border-status-error/30 bg-error-container text-status-error font-body-sm text-body-sm flex items-center gap-2">
                    <span class="material-symbols-outlined text-sm">error</span>
                    @TempData["Mensaje"]
                </div>
            }
            @RenderBody()
        </main>

    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>